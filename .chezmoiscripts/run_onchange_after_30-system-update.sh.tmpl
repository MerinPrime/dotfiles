!/bin/bash
# i2c-modules hash: {{ include "dot_config/system/modules/i2c.conf" | sha256sum }}

set -e

echo "--- Setting modules ---"
sudo cp -f "$HOME/.config/system/modules/i2c.conf" "/etc/modules-load.d/i2c.conf"
sudo usermod -aG i2c {{ .chezmoi.username }}

echo "--- Updating GRUB configuration ---"

FILE="/etc/default/grub"
PARAMS="quiet splash loglevel=3 systemd.show_status=false rd.udev.log_level=3 vt.global_cursor_default=0 nvidia-drm.modeset=1"
GRUB_CHANGED=0

if [ ! -f "$FILE" ]; then
    echo "ERROR: $FILE not found!"
    exit 1
fi

for param in $PARAMS; do
    if ! grep -q "\b$param\b" "$FILE"; then
        sudo sed -i "s/^\(GRUB_CMDLINE_LINUX_DEFAULT=\(['\"]\)\)/\1${param} /" "$FILE"
        GRUB_CHANGED=1
    fi
done

if [ "$GRUB_CHANGED" -eq 1 ]; then
    sudo sed -i '/^GRUB_CMDLINE_LINUX_DEFAULT=/s/  */ /g' "$FILE"
    sudo sed -i "/^GRUB_CMDLINE_LINUX_DEFAULT=/s/ ' / '/g" "$FILE"
    sudo sed -i '/^GRUB_CMDLINE_LINUX_DEFAULT=/s/ " / "/g' "$FILE"
    
    echo "--- Generating new grub.cfg ---"
    sudo grub-mkconfig -o /boot/grub/grub.cfg
else
    echo "--- GRUB is already optimized ---"
fi

echo "--- Configuring Plymouth ---"
sudo mkdir -p /etc/plymouth
if [ -f /etc/plymouth/plymouthd.conf ]; then
    sudo sed -i 's/.*ShowDelay.*/ShowDelay=0/' /etc/plymouth/plymouthd.conf
else
    sudo bash -c 'echo -e "[Daemon]\nShowDelay=0" > /etc/plymouth/plymouthd.conf'
fi

echo "--- Checking mkinitcpio ---"
if systemd-detect-virt -q; then
    echo "--- VM detected: Skipping NVIDIA modules to avoid errors ---"
    sudo mkinitcpio -P
else
    if ! grep -q "nvidia" /etc/mkinitcpio.conf; then
        sudo sed -i 's/^MODULES=(/&crc32c nvidia nvidia_modeset nvidia_uvm nvidia_drm /' /etc/mkinitcpio.conf
        sudo mkinitcpio -P
    else
        echo "--- mkinitcpio modules are already set ---"
    fi
fi

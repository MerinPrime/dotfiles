$text_color    = rgb({{ .colors.hyprlock.text | trimPrefix "#" }})
$accent_color  = rgb({{ .colors.hyprlock.accent | trimPrefix "#" }})
$bg_color      = rgb({{ .colors.hyprlock.background | trimPrefix "#" }})

general {
    no_fade_in = false
    grace = 0
    disable_loading = true
}

background {
    monitor =
    path = ~/.local/share/wallpapers/tokyo-red.png
    color = $bg_color
    blur_passes = 4
    blur_size = 3
    noise = 0.0117
    contrast = 0.8916
    brightness = 0.4172
    vibrancy = 0.1696
    vibrancy_darkness = 0.0
}

input-field {
    monitor =
    size = 250, 60
    outline_thickness = 2
    dots_size = 0.2
    dots_spacing = 0.2
    dots_center = true
    outer_color = $accent_color
    inner_color = $bg_color
    font_color = $text_color
    fade_on_empty = false
    placeholder_text = <i>Enter password...</i>
    hide_input = false
    position = 0, -120
    halign = center
    valign = center
}

label {
    monitor =
    text = $TIME
    color = $text_color
    font_size = 100
    font_family = JetBrainsMono Nerd Font ExtraBold
    position = 0, 80
    halign = center
    valign = center
}

label {
    monitor =
    text = Hello, $USER
    color = $text_color
    font_size = 25
    font_family = JetBrainsMono Nerd Font
    position = 0, -40
    halign = center
    valign = center
}
